{
  "$schema": "https://schema.agentcore.aws.dev/v1/agentcore.json",
  "name": "WellnessAgent",
  "version": 1,
  "managedBy": "CDK",
  "tags": {
    "agentcore:created-by": "agentcore-cli",
    "agentcore:project-name": "WellnessAgent"
  },
  "runtimes": [
    {
      "name": "WellnessAgent",
      "build": "CodeZip",
      "entrypoint": "main.py",
      "codeLocation": "app/WellnessAgent/",
      "runtimeVersion": "PYTHON_3_14",
      "networkMode": "PUBLIC",
      "protocol": "HTTP"
    }
  ],
  "memories": [],
  "credentials": [],
  "evaluators": [],
  "onlineEvalConfigs": [],
  "agentCoreGateways": [
    {
      "name": "wellness-tools-gateway",
      "description": "Gateway for wellness-tools-gateway",
      "targets": [
        {
          "name": "wellness-weather-target",
          "targetType": "lambdaFunctionArn",
          "lambdaFunctionArn": {
            "lambdaArn": "arn:aws:lambda:ap-northeast-1:YOUR_AWS_ACCOUNT_ID:function:YOUR_MCP_SERVER_FUNCTION_NAME",
            "toolSchemaFile": "schemas/weather_tool_schema.json"
          }
        }
      ],
      "authorizerType": "NONE",
      "enableSemanticSearch": true,
      "exceptionLevel": "NONE"
    }
  ],
  "policyEngines": [],
  "configBundles": [],
  "abTests": [],
  "httpGateways": []
}
